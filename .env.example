# Monatise runtime
MONATISE_MODE=paper
MONATISE_NETWORK=testnet
MONATISE_PORT=4174
MONATISE_SYMBOL=BTC
MONATISE_QUOTE=10000
MONATISE_BASE=0.05
MONATISE_SPACING_PCT=0.005
MONATISE_LEVELS_EACH_SIDE=5
MONATISE_ORDER_QUOTE_SIZE=250
MONATISE_FEE_RATE=0.0004
MONATISE_POLL_SECONDS=5

# Risk limits
MONATISE_MAX_ORDER_NOTIONAL=250
MONATISE_MAX_TOTAL_NOTIONAL=1500
MONATISE_MAX_BASE_INVENTORY=0.1
MONATISE_MAX_DAILY_LOSS=100

# Real order gates. Do not set these until you are ready for real-money risk.
MONATISE_ALLOW_LIVE_ORDERS=false
MONATISE_LIVE_CONFIRMATION=

# Hyperliquid live/testnet secrets. Never commit real values.
HYPERLIQUID_ACCOUNT_ADDRESS=
HYPERLIQUID_SECRET_KEY=
