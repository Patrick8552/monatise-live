# Monatise runtime
MONATISE_MODE=paper
MONATISE_NETWORK=testnet
MONATISE_PORT=4174
MONATISE_SYMBOL=BTC
MONATISE_QUOTE=10000
MONATISE_BASE=0.05
MONATISE_SPACING_PCT=0.005
MONATISE_LEVELS_EACH_SIDE=5
MONATISE_ORDER_QUOTE_SIZE=250
MONATISE_FEE_RATE=0.0004
MONATISE_POLL_SECONDS=5
MONATISE_EXECUTION_MODE=dry_run
MONATISE_EXCHANGE=hyperliquid

# Risk limits
MONATISE_MAX_ORDER_NOTIONAL=250
MONATISE_MAX_TOTAL_NOTIONAL=1500
MONATISE_MAX_BASE_INVENTORY=0.1
MONATISE_MAX_DAILY_LOSS=100
MONATISE_MAX_MARK_MOVE_PCT=0.03
MONATISE_MAX_POSITION_VALUE=1000
MONATISE_MIN_ACCOUNT_VALUE=0
MONATISE_ORDER_REFRESH_SECONDS=30

# Real order gates. Do not set these until you are ready for real-money risk.
MONATISE_ALLOW_LIVE_ORDERS=false
MONATISE_LIVE_CONFIRMATION=

# Hyperliquid live/testnet secrets. Never commit real values.
HYPERLIQUID_ACCOUNT_ADDRESS=
HYPERLIQUID_SECRET_KEY=

# Stripe private billing. Use Stripe-hosted Checkout; never commit real keys.
STRIPE_SECRET_KEY=
STRIPE_PRIVATE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=

# Backpack exchange scaffold. Market-data support is visible; live execution is disabled.
BACKPACK_REST_BASE=https://api.backpack.exchange
BACKPACK_API_KEY=
BACKPACK_SECRET_KEY=
BACKPACK_SYMBOL_MAP=BTC=BTC_USDC_PERP,ETH=ETH_USDC_PERP,SOL=SOL_USDC_PERP
